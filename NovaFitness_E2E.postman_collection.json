        },
        {
          "name": "3.4 Get comida actual",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/v1/diet/current-meal", "host": ["{{BASE_URL}}"], "path": ["v1","diet","current-meal"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" }
