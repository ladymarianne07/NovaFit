            "url": { "raw": "{{BASE_URL}}/v1/diet/log-meal", "host": ["{{BASE_URL}}"], "path": ["v1","diet","log-meal"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"complete\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Advanced', () => pm.expect(pm.response.json().advanced).to.be.true);"], "type": "text/javascript" }
          }]
        },
        {
          "name": "3.6 Log comida (skip)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/diet/log-meal", "host": ["{{BASE_URL}}"], "path": ["v1","diet","log-meal"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"skip\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" }
          }]
        },
        {
          "name": "3.7 Modificar comida (add food)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/diet/modify-meal", "host": ["{{BASE_URL}}"], "path": ["v1","diet","modify-meal"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"day_type\": \"rest_day\",\n  \"meal_id\": \"desayuno\",\n  \"action\": \"add_food\",\n  \"food\": {\n    \"name\": \"Nueces\",\n    \"portion\": \"30g\",\n    \"calories\": 196.0,\n    \"protein_g\": 4.6,\n    \"carbs_g\": 4.1,\n    \"fat_g\": 19.6,\n    \"notes\": \"\"\n  }\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" }
          }]
        },
        {
          "name": "3.8 Generar alternativa de comida (IA)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/v1/diet/meals/alternative", "host": ["{{BASE_URL}}"], "path": ["v1","diet","meals","alternative"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('ALT_MEAL_INDEX', json.meal_index);",
                "pm.collectionVariables.set('ALT_DAY_TYPE', json.day_type);",
                "pm.collectionVariables.set('ALT_MEAL_JSON', JSON.stringify(json.meal));"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "3.9 Aplicar alternativa (scope: today)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/diet/meals/apply-alternative", "host": ["{{BASE_URL}}"], "path": ["v1","diet","meals","apply-alternative"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meal_index\": 2,\n  \"day_type\": \"rest_day\",\n  \"scope\": \"today\",\n  \"meal\": {\n    \"id\": \"meal_alt\",\n    \"name\": \"Salmon con Quinoa\",\n    \"time\": \"Almuerzo\",\n    \"foods\": [\n      {\n        \"name\": \"Salmon\",\n        \"portion\": \"150g\",\n        \"calories\": 312.0,\n        \"protein_g\": 37.5,\n        \"carbs_g\": 0.0,\n        \"fat_g\": 18.0,\n        \"notes\": \"A la plancha\"\n      },\n      {\n        \"name\": \"Quinoa cocida\",\n        \"portion\": \"100g\",\n        \"calories\": 120.0,\n        \"protein_g\": 4.1,\n        \"carbs_g\": 21.3,\n        \"fat_g\": 1.9,\n        \"notes\": \"\"\n      }\n    ],\n    \"total_calories\": 432.0,\n    \"total_protein_g\": 41.6,\n    \"total_carbs_g\": 21.3,\n    \"total_fat_g\": 19.9,\n    \"notes\": \"\"\n  }\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 204 (sin body)', () => pm.response.to.have.status(204));"], "type": "text/javascript" }
          }]
        }
      ]
    },
