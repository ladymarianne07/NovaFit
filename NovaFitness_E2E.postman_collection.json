{
  "info": {
    "name": "NovaFitness — E2E Flow",
    "_postman_id": "novafitness-e2e-v1",
    "description": "End-to-end flow: Register → Login → Routine (AI) → Diet (AI) → Log meal → Food IA → Alternativa → Workout → Routine session → Macros/Energía",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000" },
    { "key": "TOKEN",    "value": "" },
    { "key": "SESSION_ID_WORKOUT", "value": "" },
    { "key": "ROUTINE_SESSION_ID", "value": "full_body_a" }
  ],
  "item": [
    {
      "name": "1 — Auth",
      "item": [
        {
          "name": "1.1 Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/auth/register", "host": ["{{BASE_URL}}"], "path": ["auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2e@novafitness.app\",\n  \"first_name\": \"Ana\",\n  \"last_name\": \"Test\",\n  \"password\": \"TestPass123!\",\n  \"role\": \"student\",\n  \"age\": 28,\n  \"gender\": \"female\",\n  \"weight\": 65.0,\n  \"height\": 165.0,\n  \"activity_level\": 1.35,\n  \"objective\": \"fat_loss\",\n  \"aggressiveness_level\": 2\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"], "type": "text/javascript" }
          }]
        },
        {
          "name": "1.2 Login → guarda TOKEN",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/auth/login", "host": ["{{BASE_URL}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2e@novafitness.app\",\n  \"password\": \"TestPass123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('TOKEN', json.access_token);",
                "pm.test('Token guardado', () => pm.expect(json.access_token).to.be.a('string'));"
              ],
              "type": "text/javascript"
            }
          }]
        }
      ]
    },
    {
      "name": "2 — Rutina",
      "item": [
        {
          "name": "2.1 Generar rutina (IA)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/routines/generate", "host": ["{{BASE_URL}}"], "path": ["v1","routines","generate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intake\": {\n    \"objective\": \"fat_loss\",\n    \"duration_months\": 1,\n    \"health_conditions\": \"ninguna\",\n    \"medications\": \"\",\n    \"injuries\": \"\",\n    \"preferred_exercises\": \"cardio y fuerza\",\n    \"frequency_days\": \"3-4\",\n    \"experience_level\": \"intermedio\",\n    \"equipment\": \"gimnasio completo\",\n    \"session_duration_minutes\": 60\n  },\n  \"free_text\": \"Quiero perder grasa y mejorar mi resistencia\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Rutina ready', () => pm.expect(json.status).to.eql('ready'));",
                "const sessions = json.routine_data?.sessions ?? [];",
                "if (sessions.length > 0) pm.collectionVariables.set('ROUTINE_SESSION_ID', sessions[0].id);"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "2.2 Editar rutina (IA)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/routines/edit", "host": ["{{BASE_URL}}"], "path": ["v1","routines","edit"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"edit_instruction\": \"Reemplaza los ejercicios de pierna por ejercicios de core y espalda baja\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" }
          }]
        },
        {
          "name": "2.3 Get rutina activa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/v1/routines/active", "host": ["{{BASE_URL}}"], "path": ["v1","routines","active"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" }
          }]
        },
        {
          "name": "2.4 Log sesión de rutina",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/routines/log-session", "host": ["{{BASE_URL}}"], "path": ["v1","routines","log-session"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{ROUTINE_SESSION_ID}}\",\n  \"session_date\": \"2026-04-03\",\n  \"skipped_exercise_ids\": [],\n  \"extra_exercises\": [\n    {\n      \"name\": \"Plancha abdominal\",\n      \"duration_minutes\": 10,\n      \"exercise_type\": \"resistance\"\n    }\n  ]\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"], "type": "text/javascript" }
          }]
        },
        {
          "name": "2.5 Avanzar sesión de rutina",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/routines/advance-session", "host": ["{{BASE_URL}}"], "path": ["v1","routines","advance-session"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"complete\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" }
          }]
        }
      ]
    },
    {
      "name": "3 — Dieta",
      "item": [
        {
          "name": "3.1 Generar dieta (IA)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": { "raw": "{{BASE_URL}}/v1/diet/generate", "host": ["{{BASE_URL}}"], "path": ["v1","diet","generate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intake\": {\n    \"meals_count\": 4,\n    \"dietary_restrictions\": \"ninguna\",\n    \"food_allergies\": \"ninguna\",\n    \"health_conditions\": \"ninguna\",\n    \"disliked_foods\": \"higado\",\n    \"budget_level\": \"moderado\",\n    \"cooking_time\": \"moderado\",\n    \"training_days\": [\"lunes\", \"miercoles\", \"viernes\"]\n  },\n  \"free_text\": \"Prefiero comidas simples y variadas, con proteína en cada comida\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Dieta ready', () => pm.expect(pm.response.json().status).to.eql('ready'));"], "type": "text/javascript" }
          }]
        },
        {
          "name": "3.2 Editar dieta (IA)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
